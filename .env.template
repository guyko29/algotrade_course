# Copy this file to `.env` and adjust values for your environment.
#   cp .env.template .env        (macOS / Linux)
#   copy .env.template .env    (Windows)

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# --- TASE market data (public API — no key required today) ---
# Optional: TASE DataHub API key if you migrate to the official paid API.
TASE_API_KEY=
TASE_INDEX_API_URL=https://api.tase.co.il/api/index/historyeod
TASE_SECURITY_API_URL=https://api.tase.co.il/api/security/historyeod
TASE_REQUEST_TIMEOUT_SECONDS=20

# --- Portfolio defaults ---
DEFAULT_BENCHMARK=TA35
DEFAULT_RISK_FREE_RATE_ANNUAL=0.045
LOOKBACK_YEARS=3
MIN_OVERLAPPING_TRADING_DAYS=60

# --- ML expected-return forecasting ---
# ML_MODEL: xgboost | ridge | linear | random_forest (primary regressor for drift)
ML_MODEL=xgboost
# Forecast horizon in trading days (21 ≈ one month).
ML_HORIZON_DAYS=21
# Minimum feature rows required to train; below this we fall back to historical mean.
ML_MIN_TRAIN_ROWS=252
# Shrinkage of the ML prediction toward the historical mean (0=pure historical, 1=pure ML).
ML_SHRINKAGE=0.5

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
